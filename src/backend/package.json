{
  "name": "badnet-backend",
  "version": "1.0.0",
  "description": "BadNet - Badminton Social Platform Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "migrate": "node dist/database/migrations.js",
    "seed": "node dist/database/seeders.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "badminton",
    "social",
    "platform",
    "tournament",
    "matches"
  ],
  "author": "BadNet Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "typeorm": "^0.3.16",
    "jsonwebtoken": "^9.1.0",
    "bcrypt": "^5.1.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.4.5",
    "@types/jest": "^29.5.3",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "jest": "^29.6.3",
    "ts-jest": "^29.1.1",
    "eslint": "^8.46.0",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "prettier": "^3.0.1"
  }
